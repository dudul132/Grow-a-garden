-- [ 4. LOGIC TRACKING (FINAL FIX) ] --
local lastHP = 100

local function track(char)
	local hum = char:WaitForChild("Humanoid", 10)
	if not hum then return end

	-- RESET VISUAL SAAT RESPAWN (Fix Darah Gak Muncul)
	MainFrame.Visible = true
	MainFrame.Size = UDim2.new(0, 0, 0, 0) -- Pastikan mulai dari 0 untuk efek pop
	
	-- Update Avatar
	Avatar.Image = Players:GetUserThumbnailAsync(LocalPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
	
	-- Update Darah Langsung (Supaya bar terisi penuh saat spawn)
	HBFill.Size = UDim2.new(math.clamp(hum.Health/hum.MaxHealth, 0, 1), 0, 1, 0)
	HBFill.BackgroundColor3 = Color3.fromRGB(60, 200, 80) -- Reset warna hijau
	lastHP = hum.Health

	-- Animasi Muncul GUI
	MainFrame:TweenSize(UDim2.new(0, 200, 0, 60), "Out", "Back", 0.6, true)

	-- Listener Perubahan Darah
	local hpChange
	hpChange = hum.HealthChanged:Connect(function(hp)
		local ratio = math.clamp(hp/hum.MaxHealth, 0, 1)
		
		-- Animasi Bar
		HBFill:TweenSize(UDim2.new(ratio, 0, 1, 0), "Out", "Quad", 0.2, true)
		
		-- Ganti warna bar kalau sekarat
		if ratio < 0.3 then
			HBFill.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
		else
			HBFill.BackgroundColor3 = Color3.fromRGB(60, 200, 80)
		end

		-- VFX Hati kalau berkurang
		if hp < lastHP then spawnHeartVFX() end
		lastHP = hp
	end)

	-- Listener Kematian
	local died
	died = hum.Died:Connect(function()
		hpChange:Disconnect() -- Putus koneksi darah biar gak error
		died:Disconnect()
		
		-- Animasi Hilang
		MainFrame:TweenSize(UDim2.new(0, 0, 0, 0), "In", "Back", 0.5, true, function()
			MainFrame.Visible = false -- Sembunyikan total
		end)
	end)
end

-- Init Script
if LocalPlayer.Character then 
	task.spawn(track, LocalPlayer.Character) 
end


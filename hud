-- [ 3. VFX SYSTEM ] --
local function spawnHeartVFX()
	for i = 1, 6 do
		task.spawn(function()
			local h = Instance.new("TextLabel", ScreenGui)
			h.Size = UDim2.new(0, 30, 0, 30)
			h.Position = MainFrame.Position
			h.BackgroundTransparency = 1
			h.Text = "♡"
			h.TextColor3 = Color3.fromRGB(255, 100, 100)
			h.TextTransparency = 0.4
			h.TextSize = 25
			
			local rX = math.random(-80, 80)
			local rY = math.random(-80, 20)
			
			-- Menyebar
			TweenService:Create(h, TweenInfo.new(0.8, Enum.EasingStyle.Quart), {
				Position = h.Position + UDim2.new(0, rX, 0, rY),
				Rotation = math.random(-45, 45)
			}):Play()
			
			task.wait(0.6)
			
			-- Jatuh & Hilang
			TweenService:Create(h, TweenInfo.new(2, Enum.EasingStyle.Sine), {
				Position = h.Position + UDim2.new(0, rX, 0, 200),
				TextTransparency = 1
			}):Play()
			
			Debris:AddItem(h, 2.5)
		end)
	end
end

-- Animasi Kilau Teks Loop
task.spawn(function()
	while true do
		task.wait(7) -- Setiap 7 detik
		-- Reset Offset ke kiri
		TextGradient.Offset = Vector2.new(-1, 0)
		-- Jalan ke kanan (Kilap lewat)
		local tween = TweenService:Create(TextGradient, TweenInfo.new(1.5, Enum.EasingStyle.Quad), {Offset = Vector2.new(1, 0)})
